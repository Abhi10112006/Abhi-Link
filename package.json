{
  "name": "abhi-link-monorepo",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/web",
    "apps/mobile"
  ],
  "scripts": {
    "web": "npm run dev --workspace=apps/web",
    "mobile": "npm run start --workspace=apps/mobile",
    "lint:web": "npm run lint --workspace=apps/web",
    "lint:mobile": "npm run lint --workspace=apps/mobile",
    "lint": "npm run lint:web && npm run lint:mobile"
  }
}
